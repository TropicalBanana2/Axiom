{
  "name": "axiom-server",
  "version": "0.1.0",
  "private": true,
  "description": "Axiom — self-hosted zombs.io shell. Three engines: ui, scripting, sessions.",
  "main": "src/localhost.js",
  "type": "commonjs",
  "scripts": {
    "start": "pm2 start ecosystem.config.js",
    "stop": "pm2 stop ecosystem.config.js",
    "logs": "pm2 logs",
    "dev:localhost": "node src/localhost.js",
    "dev:sessions": "node src/sessions.js",
    "dev:sockets": "node src/sockets.js",
    "db:reset": "node src/db.js --reset"
  },
  "dependencies": {
    "better-sqlite3": "^11.3.0",
    "bytebuffer": "^5.0.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.2",
    "pm2": "^7.0.1",
    "ws": "^8.21.0"
  }
}
